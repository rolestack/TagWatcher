# =============================================================================
# TagWatcher Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Public URL of this TagWatcher instance (no trailing slash)
APP_URL=https://your-domain.com

# Long random secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32

# Set to true for development (enables /api/docs, verbose logging)
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# The database connection is configured through the web setup wizard on first
# launch and stored in /app/data/tagwatcher.json (Docker volume).
#
# You can skip the DB step in the wizard by pre-setting DATABASE_URL here,
# but it is NOT required — the wizard handles it interactively.
#
#DATABASE_URL=postgresql+asyncpg://tagwatcher:changeme@db:5432/tagwatcher

# PostgreSQL container credentials (used by the db service in docker-compose)
POSTGRES_PASSWORD=<your-secure-password>

# ---------------------------------------------------------------------------
# OIDC / SSO Authentication  (optional — can be configured in the web UI)
# ---------------------------------------------------------------------------
#OIDC_PROVIDER_URL=https://accounts.google.com
#OIDC_CLIENT_ID=your-client-id-here
#OIDC_CLIENT_SECRET=your-client-secret-here
#OIDC_SCOPES=openid email profile

# Emergency override: force-enable local login regardless of DB setting.
# Useful if OIDC breaks and you are locked out.
LOCAL_LOGIN_ENABLED=true

# ---------------------------------------------------------------------------
# Docker Socket Access
# ---------------------------------------------------------------------------
# Required when monitoring the local Docker host via unix:///var/run/docker.sock.
# Find the GID with: stat -c '%g' /var/run/docker.sock
DOCKER_GID=999

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------

# How often to check for image updates (in minutes)
CHECK_INTERVAL_MINUTES=60

# ---------------------------------------------------------------------------
# Reverse Proxy
# ---------------------------------------------------------------------------

# Set to true if TagWatcher is behind a reverse proxy (nginx, traefik, etc.)
BEHIND_PROXY=false

# ---------------------------------------------------------------------------
# Session / Cookie
# ---------------------------------------------------------------------------

SESSION_COOKIE_NAME=tagwatcher_session
# Session lifetime in seconds (default: 8 hours)
SESSION_MAX_AGE=28800

# ---------------------------------------------------------------------------
# Gunicorn / Server
# ---------------------------------------------------------------------------

WORKERS=2
WORKER_CLASS=uvicorn.workers.UvicornWorker
BIND=0.0.0.0:8000
TIMEOUT=120
KEEPALIVE=5

# ---------------------------------------------------------------------------
# ETC
# ---------------------------------------------------------------------------
TZ=UTC
